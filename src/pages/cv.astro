---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import EdTimeElement from "../components/cv/EdTimeElement.astro";
---

<BaseLayout title="Dimitrios Gerogiannis | CV" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Curriculum Vitae</div>
  </div>

  <div class="mb-3">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-8">
    <EdTimeElement
      date="2022 - 2027"
      educationTitle="PhD in Computing"
      university="Imperial College London, London, United Kingdom"
      studyCenterUrl="https://www.imperial.ac.uk/"
      additionalInfo={[
        { text: "3D Human Modeling" },
        { text: "3D Animation" },
        { text: "3D Diffusion Models" },
        { text: "Foundation Models" },
        { text: "Video Diffusion Models" }
      ]}
      supervisor="Professor Stefanos Zafeiriou"
      supervisorUrl="https://www.imperial.ac.uk/people/s.zafeiriou"
    />
    <EdTimeElement
      date="2017 - 2022"
      educationTitle="BSc + MEng in Computer Science"
      university="University of Patras, Patras, Greece"
      studyCenterUrl="https://www.upatras.gr/en/"
      additionalInfo={[
        { text: "GPA: 9.15/10 (Valedictorian, Class of 2022)" },
        { text: "Diploma Thesis Title: Robust image alignment under severe photometric distortions" }
      ]}
      advisor="Professor Emmanouil Z. Psarakis"
      advisorUrl="http://xanthippi.ceid.upatras.gr/people/psarakis/personal_gr.php"
    />
  </div>

  <div class="mb-3">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

<div class="time-line-container mb-10">
  <EdTimeElement
    date="February 2026 - Present"
    educationTitle="Student Researcher"
    university="Google, London, United Kingdom"
    studyCenterUrl="https://arvr.google.com"
    imageSrc="/google_arvr.png"
    imageAlt="Google AR and VR logo"
    imageBoxClass="w-72 h-20 p-3 bg-white rounded-sm"
  />

  <EdTimeElement
    date="June 2025 - December 2025"
    educationTitle="Research Scientist Intern"
    university="Meta, London, United Kingdom"
    studyCenterUrl="https://tech.facebook.com/reality-labs/"
    imageSrc="/meta_reality_labs.png"
    imageAlt="Meta Reality Labs logo"
    imageBoxClass="w-72 h-20 p-3 bg-white rounded-sm"
    imageClass="max-w-full max-h-full object-contain scale-90"
  />

  <EdTimeElement
    date="January 2024 - May 2025"
    educationTitle="Research Scientist Intern"
    university="Alloyed Limited, Oxford, United Kingdom"
    studyCenterUrl="https://alloyed.com/"
    imageSrc="/alloyed.png"
    imageAlt="Alloyed logo"
    imageBoxClass="w-72 h-20 p-3 bg-white rounded-sm"
    imageClass="max-w-full max-h-full object-contain scale-95"
  />

  <EdTimeElement
    date="October 2022 - Present"
    educationTitle="Graduate Teaching Assistant"
    university="Imperial College London, London, United Kingdom"
    studyCenterUrl="https://www.imperial.ac.uk/computing/"
    imageSrc="/imperial.png"
    imageAlt="Imperial College London logo"
    imageBoxClass="w-72 h-20 p-3 bg-white rounded-sm"
    imageClass="max-w-full max-h-full object-contain scale-90"
  />
</div>

  <div class="mb-3">
    <div class="text-3xl w-full font-bold">Awards and Honors</div>
  </div>

  <div class="time-line-container mb-10">
    <EdTimeElement
      date="2022‐2027"
      educationTitle="Doctoral Scholarship Award"
      university="DoC Imperial College London, London, United Kingdom"
      studyCenterUrl="https://www.imperial.ac.uk/computing/"
      additionalInfo={[
        { text: "Full scholarship covering tuition fees and a living stipend for the duration of the PhD program, awarded to students with strong distinction in their MSc degrees." }
      ]}
    />
    <EdTimeElement
      date="2022-2023"
      educationTitle="Student Excellence Award"
      university="States Scholarships Foundation, Athens, Greece"
      studyCenterUrl="https://www.iky.gr/en/"
      additionalInfo={[
        { text: "Awarded to the students achieving the highest GPA in their respective departments nationwide." }
      ]}
    />
    <EdTimeElement
      date="2022-2023"
      educationTitle="Graduate Excellence Honors"
      university="University of Patras, Patras, Greece"
      studyCenterUrl="https://www.upatras.gr/en/"
      additionalInfo={[
        { text: "Granted to the graduates who achieved the highest GPAs in their respective departments and classes." }
      ]}
    />
</BaseLayout>
